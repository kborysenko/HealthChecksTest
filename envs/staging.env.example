# Per-environment runtime config. Copy to envs/staging.env (gitignored) and fill in.
# Used by:  docker run --env-file envs/staging.env ui-healthcheck
#      or:  docker compose run --rm healthcheck

APP_URL=https://stg-ui.adcint.com
APP_USERNAME=you@example.com
APP_PASSWORD=change-me
HEADLESS=false

# Failure notifications
# Each channel is enabled only when its variables are set; leave blank to disable.

SLACK_WEBHOOK_URL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=alerts@example.com

# Allure report delivery on failure:
# default  -> report is LINKED (CI artifact / local path); screenshots + test summary attached (safe)
# ALLURE_ATTACH=true -> also attach the report as a password-protected zip (mail provider can't scan it)
ALLURE_ATTACH=true
ALLURE_ZIP_PASSWORD=healthcheck
# REPORT_URL=            # optional explicit link to a hosted report
